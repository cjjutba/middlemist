# ─── App ─────────────────────────────────────────────
# Canonical app origin (used in absolute URLs and Origin checks).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Auth.js ─────────────────────────────────────────
# 32-byte signing key for sessions, verification tokens, password reset.
# Generate locally: openssl rand -base64 32
# Server-only. Different per environment.
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# ─── Database ────────────────────────────────────────
# Postgres connection string. Local dev uses the docker-compose stack;
# Neon (pooled URL) in production.
# DIRECT_URL bypasses connection pooling and is used by Prisma migrations.
DATABASE_URL=postgresql://middlemist:middlemist@localhost:5432/middlemist_dev?schema=public
DIRECT_URL=postgresql://middlemist:middlemist@localhost:5432/middlemist_dev?schema=public

# ─── Email ───────────────────────────────────────────
# Resend in production. Local dev sends through Mailpit SMTP.
# RESEND_WEBHOOK_SECRET is for inbound bounce/complaint webhooks (production only).
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=

# Mailpit SMTP (remapped to host port 1026 to avoid colliding with another
# project's mailpit/mailhog on 1025). Web UI: http://localhost:8026
SMTP_HOST=localhost
SMTP_PORT=1026
SMTP_USER=
SMTP_PASS=
SMTP_FROM=hello@middlemist.local

# ─── Background jobs ─────────────────────────────────
# Inngest cloud in production; local dev server in development.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_DEV=1

# ─── File uploads (UploadThing v7) ───────────────────
# UPLOADTHING_TOKEN covers both client and server in v7.
# UPLOADTHING_SECRET is used by legacy/server-side calls.
UPLOADTHING_TOKEN=
UPLOADTHING_SECRET=

# ─── Rate limiting ───────────────────────────────────
# Upstash Redis REST in production; local Redis (ioredis) in development.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_URL=redis://localhost:6379

# Development override: short-circuits all rate limits to always-pass.
# Throws if NODE_ENV=production at startup.
DISABLE_RATE_LIMITS=true

# ─── Cron ────────────────────────────────────────────
# Bearer token Vercel attaches to scheduled invocations. Production only.
# Generate locally: openssl rand -base64 32
CRON_SECRET=

# ─── FX ──────────────────────────────────────────────
# exchangerate.host API key. Falls back to a cached rate when unavailable.
EXCHANGERATE_HOST_KEY=

# ─── Error tracking (Sentry) ─────────────────────────
# Server runtime DSN, build-time auth token (source-map upload), browser DSN.
# Production only in v1.
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=

# ─── Analytics (Plausible) ───────────────────────────
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=middlemist.app

# ─── UploadThing public host (used by sanitizer allowlist) ───
NEXT_PUBLIC_UPLOADTHING_PUBLIC_URL=https://utfs.io
